# 로컬 테스트용. 실제 운영은 GitHub Secrets 에 동일 키로 등록.
# 사용: 아래 값 채운 뒤  ->  (bash) set -a; source .env; set +a; python poller.py

# Finnhub 무료 키 (https://finnhub.io 가입 → 무료, 카드 불필요)
FINNHUB_KEY=

# ntfy.sh 토픽명 (안드로이드 ntfy 앱에서 이 토픽을 구독). 추측 어려운 이름 권장.
NTFY_TOPIC=dododong-ipo-9f3k2
# 자체 ntfy 서버 쓸 때만. 기본은 https://ntfy.sh
NTFY_SERVER=

# 선택: 디스코드 채널 웹훅 URL
DISCORD_WEBHOOK=

# 선택: 텔레그램 봇
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# SEC 가 요구하는 연락처 포함 User-Agent (기본값 있음, 바꿔도 됨)
SEC_UA=dododong.dev ipo-radar gemiddikku@gmail.com
